# GroundControl_RAG environment variables
# Copy this file to .env and fill in actual values
# .env is gitignored — never commit real secrets

# Database
DATABASE_URL=postgresql+asyncpg://groundcontrol:password@postgres:5432/groundcontrol
POSTGRES_USER=groundcontrol
POSTGRES_PASSWORD=password
POSTGRES_DB=groundcontrol

# JWT Authentication
JWT_SECRET_KEY=change-me-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Admin bootstrap credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=adminpassword

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000
